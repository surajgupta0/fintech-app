# ============================================================
# FINTECH APP - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env (development) or .env.prod (production)
# Fill in the required values before deploying
# ============================================================

# DATABASE CONFIGURATION
# Format: postgresql://user:password@host:port/database
# Local: postgresql://postgres:password@localhost:5432/fintech_db
# Cloud: Use Supabase, RDS, Cloud SQL, or CockroachDB
DATABASE_URL=postgresql://postgres:password@localhost:5432/fintech_db

# JWT SECURITY SECRETS (Min 32 characters, use strong random values)
# Generate with: openssl rand -hex 32 (or deploy.sh script)
# NEVER hardcode real secrets - use your deploy script!
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-CHANGE-THIS
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-CHANGE-THIS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SERVER CONFIGURATION
PORT=4000
NODE_ENV=development
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# FILE UPLOAD SETTINGS
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ML SERVICE CONNECTION
# Local: http://ml-service:8000 (Docker networking)
# Production: http://ml-service:8000 (same as local in Docker)
ML_SERVICE_URL=http://ml-service:8000

# OPTIONAL: FREE REMOTE ML CLASSIFICATION VIA HUGGING FACE
# If set, backend tries this API first for level-4 classification.
# You can create a free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=xyz
HF_ZERO_SHOT_URL=https://api-inference.huggingface.co/models/facebook/bart-large-mnli

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000       # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100       # Max requests per window
AUTH_RATE_LIMIT_MAX=10            # Max login attempts

# FRONTEND API ENDPOINT
# Development: http://localhost:4000/api
# Production: https://api.your-domain.com/api
VITE_API_URL=http://localhost:4000/api

# ============================================================
# QUICK START
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your values
# 3. Run: docker-compose up
# 
# For production deployment:
# 1. Copy and edit .env.prod: cp .env.example .env.prod
# 2. Run deployment script: ./deploy.sh (or deploy.ps1 on Windows)
# 3. Follow platform-specific instructions
# ============================================================
